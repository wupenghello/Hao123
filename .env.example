# ===== 和风天气（QWeather） =====
# API Key：去 https://qweather.com 注册应用并获取
VITE_QWEATHER_API_KEY=your_qweather_api_key_here

# API Host（可选）：新版账户需填写专属域名（形如 xxx.qweatherapi.com）。
# 留空或不配置时默认使用 devapi.qweather.com
# VITE_QWEATHER_API_HOST=your-dedicated-host.qweatherapi.com

# ===== 禅道（ZenTao）连接信息 =====
# 服务器地址，形如 http://zentao.example.com；子路径部署则带上，如 http://host/zentao
VITE_ZENTAO_BASE=http://your-zentao-host
VITE_ZENTAO_ACCOUNT=your_account
VITE_ZENTAO_PASSWORD=your_password

# ===== LLM 助手（小吴） =====
# 助手公共设置：名称与一句话定位（留空用默认「小吴」）
# VITE_ASSISTANT_NAME=小吴
# VITE_ASSISTANT_TAGLINE=你的工作台智能助理 —— 查天气、看禅道任务与 Bug，一句话就够。

# ★ LLM 接入参数（API Key / 模型 / Base URL）全部在页面内配置：
#   状态栏「未配置」→ 点击打开模型配置面板 → 添加 Provider 并填写 Key。
#   无需改 .env、无需重启 dev，配置即时生效。

# ===== 知识库（KB，助手「小吴」检索的项目内部文档） =====
# 来源二选一（改动后需重启 dev，本地源由 vite-plugin-kb.ts 读取）：
#   1) 本地文件夹路径（Windows 用正斜杠）：D:/projects/todayops-kb
#   2) manifest 的 http URL：须返回 JSON 数组 [{doc,title,content}, ...]
#      注意：浏览器直接 fetch（无代理），地址须与页面同源或在响应头开放 CORS，
#      否则会被浏览器跨域策略拦截。dev/prod 均如此。
VITE_KB_SOURCE=D:/projects/todayops-kb

# ===== 墨刀项目迭代原型（状态栏直接读取） =====
# 配置后，TodayOps 启动时会预取该公开墨刀原型；小吴也会默认读取这里，无需每次输入链接。
VITE_MODAO_PROJECT_URL=https://modao.cc/proto/a8bcfB7tcr2153ep61pFH/sharing?view_mode=read_only
VITE_MODAO_PROJECT_LABEL=2026迭代

# ===== wbscf-web 代码库（dev 服务一键启动） =====
# 指向 wbscf-web 仓库根目录（Windows 用正斜杠）：D:/projects/wbscf-web
# 由根目录 vite-plugin-wbscf.ts 在 dev 时读其 package.json、拉起 dev:* 脚本并探测端口。
# 状态栏左上角导航（账号/买卖家/运营/ERP）hover 菜单 dev 前会出现 localhost 入口；
# 点击启动本地 dev 服务（已在运行则直接打开、不重复拉起），运行中以绿点标记。
# 改动后需重启 dev；未配置则入口隐藏。仅 dev 生效，生产构建无 dev server 自动降级。
VITE_WBSCF_WEB_ROOT=D:/projects/wbscf-web
# 包管理器（可选，默认 pnpm）：pnpm / npm / yarn，用于运行 dev:* 脚本
# VITE_WBSCF_PKG_MGR=pnpm
