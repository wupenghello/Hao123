# 和风天气
# API Key：去 https://qweather.com 注册应用并获取。
VITE_QWEATHER_API_KEY=your_qweather_api_key_here
# API Host 可选：新版账户通常需要填写专属域名，留空则默认 devapi.qweather.com。
# VITE_QWEATHER_API_HOST=your-dedicated-host.qweatherapi.com

# 禅道
# 子路径部署需带上路径，例如 http://host/zentao。
VITE_ZENTAO_BASE=http://your-zentao-host
VITE_ZENTAO_ACCOUNT=your_account
VITE_ZENTAO_PASSWORD=your_password
# 演示模式可选：true 时使用本地假数据。
# VITE_ZENTAO_MOCK=true

# 助手显示文案（可选，留空使用默认值）
# VITE_ASSISTANT_NAME=小吴
# VITE_ASSISTANT_TAGLINE=你的工作台智能助理 —— 查天气、看禅道任务与 Bug，一句话就够。

# 大模型线路不再写入 .env：在页面内「模型线路控制台」配置 Provider / API Key / Base URL / 模型列表。

# 知识库：本地 Markdown 目录或远程 JSON manifest。
# 本地路径 Windows 用正斜杠；远程 manifest 需返回 [{doc,title,content}, ...] 且允许浏览器跨域访问。
VITE_KB_SOURCE=D:/projects/todayops-kb

# 墨刀原型
# 配置公开原型链接后，状态栏和小吴可直接读取该原型。
VITE_MODAO_PROJECT_URL=https://modao.cc/proto/your-project/sharing?view_mode=read_only
VITE_MODAO_PROJECT_LABEL=项目迭代原型

# wbscf-web 本地仓库：用于本地 dev 服务、Git 仪表盘和 Claude 启动入口。
# 指向 wbscf-web 仓库根目录；仅 dev 生效，改动后需重启 dev server。
VITE_WBSCF_WEB_ROOT=D:/projects/wbscf-web
# 包管理器可选，默认 pnpm：pnpm / npm / yarn。
# VITE_WBSCF_PKG_MGR=pnpm

# Agent Reach 外部调研能力：仅 dev 生效。
# 开启后小吴可在用户主动要求时搜索公开互联网、读网页、分析 GitHub 仓库、总结 YouTube/B站视频。
# 需要先安装 Agent Reach 及对应上游工具；未安装时 reach.status 会给出诊断。
# VITE_AGENT_REACH_ENABLED=true
# VITE_AGENT_REACH_CMD=agent-reach

# 项目画像（可选，仅 reachEnabled 时注入对话上下文）：
# 用一句话描述本项目的技术栈 / 阶段 / 约束，让小吴在「外部调研」回答的「对本项目的影响」段落有落地锚点。
# 不配置时回退到通用引入评估维度（兼容性 / 体积 / 维护风险）。
# VITE_PROJECT_PROFILE=Vue3 + TS + Vite 工作台，前端单体，无 SSR，集成禅道/天气/KB
